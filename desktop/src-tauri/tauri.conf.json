{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Asayn",
  "version": "0.5.19",
  "identifier": "com.asayn.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build && npm run build:sidecar",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{ "title": "Asayn", "width": 1360, "height": 860, "minWidth": 940, "minHeight": 640, "decorations": false, "transparent": true }],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "externalBin": ["binaries/asayn-bridge"]
  }
}
