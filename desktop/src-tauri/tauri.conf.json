{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Asayn",
  "version": "0.5.1",
  "identifier": "com.asayn.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build && npm run build:sidecar",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{ "title": "Asayn", "width": 1360, "height": 860, "minWidth": 940, "minHeight": 640, "decorations": true, "transparent": false }],
    "security": { "csp": null }
  },
  "bundle": { "active": true, "targets": "all", "icon": ["../../assets/icon.png"], "externalBin": ["binaries/asayn-bridge"] }
}
